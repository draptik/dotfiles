{
  "layer": "top",
  "position": "bottom",
  "modules-left": [
    "custom/scratchpad_indicator",
    "idle_inhibitor",
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [],
  "modules-right": [
    "battery",
    "cpu",
    "network",
    "pulseaudio",
    "clock#date",
    "clock#time",
    "tray"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "disable-click": true
  },
  "tray": {
    "spacing": 8,
    "icon-size": 10
  },
  "clock#date": {
    "format": "пЃі {:%a %e %b %Y}",
    "tooltip-format": "{:%a %e %B %Y}"
  },
  "clock#time": {
    "interval": 60,
    "format": "{:%H:%M}"
  },
  "cpu": {
    "format": "cpu:{usage:2}%"
  },
  "memory": {
    "format": "пѓ‰ {}%"
  },
  "temperature": {
    "critical-threshold": 75,
    "format": "п‹‰ {temperatureC}В°C"
  },
  "battery": {
    "bat": "BAT0",
    "interval": 30,
    "full-at": 95,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity:3}%",
    "format-charging": "{icon} {capacity:3}% &#128268; ",
    "format-plugged": "{icon} {capacity:3}% &#128268;&#127793; ",
    "format-discharging": "{icon} {capacity:3}%рџ”‹ ",
    "format-icons": [
      "п‰„",
      "п‰ѓ",
      "п‰‚",
      "п‰Ѓ",
      "п‰Ђ"
    ]
  },
  "network": {
    "format-wifi": "п‡« {essid}",
    "tooltip-format-wifi": "п‡«  {essid} {ipaddr} ({signalStrength}%)",
    "format-ethernet": "пћ– ",
    "tooltip-format-ethernet": "{ipaddr}",
    "format-disconnected": "вљ  Disconnected"
  },
  "pulseaudio": {
    "format": "{icon} {volume:3}%",
    "format-muted": "рџ”‡",
    "format-icons": {
      "headphones": "пЂҐ",
      "default": [
        "пЂ§",
        "пЂЁ"
      ]
    },
    "on-click": "pavucontrol"
  },
  "sway/language": {
    "format": "вЊЁ {} "
  },
  "sway/mode": {
    "format": "<span>вљЎпёЏ {}</span>",
    "tooltip": false
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "рџ–ҐпёЏ",
      "deactivated": "рџ”“"
    }
  },
  "custom/scratchpad_indicator": {
    "interval": 3,
    "return-type": "json",
    "exec": "swaymsg -t get_tree | jq --unbuffered --compact-output '(recurse(.nodes[]) | select(.name == \"__i3_scratch\") | .focus) as $scratch_ids | [..  | (.nodes? + .floating_nodes?) // empty | .[] | select(.id |IN($scratch_ids[]))] as $scratch_nodes | if ($scratch_nodes|length) > 0 then { text: \"\\($scratch_nodes | length)\", tooltip: $scratch_nodes | map(\"\\(.app_id // .window_properties.class) (\\(.id)): \\(.name)\") | join(\"\\n\") } else empty end'",
    "format": "{}рџ““",
    "on-click": "exec swaymsg 'scratchpad show'",
    "on-click-right": "exec swaymsg 'move scratchpad'"
  }
}
